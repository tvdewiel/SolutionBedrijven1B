<Window x:Class="BedrijvenWPFAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BedrijvenWPFAdmin"
        mc:Ignorable="d"
        Title="Bedrijvenbeheer" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="0" Margin="5" Name="DataGridBedrijven" SelectionChanged="DataGridBedrijven_SelectionChanged">
            
        </DataGrid>
        <DataGrid Grid.Row="1" Margin="5" Name="DataGridPersoneel">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Nieuw personeelslid"/>
                    <MenuItem Header="Update personeelslid"/>
                    <MenuItem Header="Verwijder personeelslid" Click="VerwijderPersoneel_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Window>
